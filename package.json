{
  "name": "memory-markdown",
  "version": "1.0.0",
  "description": "Filesystem-based memory storage with Markdown and frontmatter. Human-readable, lightweight memory system for AI agents.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./storage": {
      "types": "./dist/storage/types.d.ts",
      "default": "./dist/storage/filesystem.js"
    },
    "./index-manager": {
      "types": "./dist/index/manager.d.ts",
      "default": "./dist/index/manager.js"
    }
  },
  "files": [
    "SKILL.md",
    "_meta.json",
    "README.md",
    "openclaw.plugin.json",
    "dist"
  ],
  "openclaw": {
    "extensions": [
      "./dist/plugin.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "prepublishOnly": "tsc"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.11"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": "^2026.3.24-beta.2",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "memory",
    "markdown",
    "frontmatter",
    "filesystem",
    "notes",
    "knowledge-base",
    "long-term-memory",
    "persistent-memory",
    "ai-agent",
    "openclaw",
    "moltbot",
    "claude",
    "claude-code",
    "context-management"
  ],
  "license": "MIT",
  "author": "OpenClaw",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/memory-markdown"
  },
  "homepage": "https://github.com/openclaw/memory-markdown",
  "bugs": {
    "url": "https://github.com/openclaw/memory-markdown/issues"
  }
}
